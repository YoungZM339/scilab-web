{
  "name": "scilab-web",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "科研实验室主页与内容管理系统",
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:docker": "bash scripts/docker-smoke.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:backup": "tsx scripts/backup.ts",
    "admin:create": "tsx scripts/admin.ts create",
    "admin:reset-password": "tsx scripts/admin.ts reset-password",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@tiptap/core": "3.27.4",
    "@tiptap/extension-image": "3.27.4",
    "@tiptap/extension-link": "3.27.4",
    "@tiptap/html": "3.27.4",
    "@tiptap/react": "3.27.4",
    "@tiptap/starter-kit": "3.27.4",
    "better-auth": "1.6.23",
    "better-sqlite3": "12.11.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "file-type": "22.0.1",
    "lucide-react": "0.468.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.71.1",
    "sanitize-html": "2.17.6",
    "sharp": "0.35.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tsx": "4.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "28.0.0",
    "prettier": "3.9.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
